{
  "manifest_version": 3,
  "name": "Dragcave Egg Identifier",
  "description": "Chrome extension to identify the eggs on dragcave.net.",
  "version": "1.0.0",
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://dragcave.net/*"
  ],
  "icons": {
    "16": "favicon_16.png",
    "32": "favicon_32.png",
    "48": "favicon_48.png",
    "128": "favicon_128.png"
  },
  "action": {
    "default_title": "Dragcave",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "favicon_16.png",
      "32": "favicon_32.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://dragcave.net/*"
      ],
      "js": [
        "logic.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "inject.css",
        "sprite.png"
      ],
      "matches": [
        "https://dragcave.net/*"
      ]
    }
  ]
}
